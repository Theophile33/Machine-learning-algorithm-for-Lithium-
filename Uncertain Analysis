axes7[0].fill_between(x_sorted, 
                      mean_predictions[sorted_idx] - confidence_interval[sorted_idx],
                      mean_predictions[sorted_idx] + confidence_interval[sorted_idx],
                      alpha=0.3, color='gray', label='95% Confidence Interval')
axes7[0].plot(x_sorted, y_test.values[sorted_idx], 'b-', linewidth=1.5, 
              alpha=0.8, label='Actual Values')
axes7[0].plot(x_sorted, mean_predictions[sorted_idx], 'r-', linewidth=2,
              label='Predicted Mean')
